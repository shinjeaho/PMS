TZ=Asia/Seoul

# Container port exposure
PMS_HOST_PORT=5000
PMS_PORT=5000
PMS_THREADS=8

# Flask session key: 반드시 실제 운영용 임의 문자열로 교체
PMS_SECRET_KEY=change-this-to-a-long-random-string

# Backup behavior
PMS_BACKUP_ON_START=0
PMS_DAILY_BACKUP=0
PMS_DAILY_BACKUP_TIME=00:00

# Database connection
# 같은 NAS의 MariaDB를 쓰면 NAS IP 또는 docker 네트워크 서비스명을 넣으세요.
PMS_DB_PROFILE=default
PMS_DB_HOST=192.168.0.10
PMS_DB_USER=root
PMS_DB_PASSWORD=0000
PMS_DB_NAME=PMS